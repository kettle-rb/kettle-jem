#!/usr/bin/env ruby
# frozen_string_literal: true

# vim: set syntax=ruby

# kettle-jem: initialize a target gem repo to use kettle-jem tooling.
# This script is installed into PATH when the kettle-jem gem is installed.
# It is designed to be run from inside the target gem's repository working
# directory. It will not assume kettle-jem is already a dependency.

# Ensure output is flushed promptly even if we exit early
$stdout.sync = true
$stderr.sync = true

require "rubygems"

script_basename = File.basename(__FILE__)

# Early environment snapshot — captured before any gem requires that might
# modify ENV. Helps diagnose cases where direnv/dotenv variables are lost.
if ENV.fetch("DEBUG", "false").to_s.strip.casecmp("true").zero?
  $stderr.puts("[kettle-jem] Early env snapshot (before requires):")
  %w[KETTLE_RB_DEV BUNDLE_GEMFILE BUNDLE_PATH GEM_HOME GEM_PATH RUBYOPT RUBYLIB PWD].each do |key|
    $stderr.puts("  #{key}=#{ENV[key].inspect}")
  end
  require "open3"
  git_out, _st = Open3.capture2("git status --porcelain")
  $stderr.puts("  git status --porcelain: #{git_out.strip.empty? ? "clean" : "DIRTY"}")
  git_out.each_line { |l| $stderr.puts("    #{l.rstrip}") } unless git_out.strip.empty?
end

begin
  # Standard Library
  require "fileutils"
  require "shellwords"
  require "open3"
  require "optparse"

  require_relative "../lib/kettle/jem/version"
  require_relative "../lib/kettle/jem/setup_cli"
  puts "== #{script_basename} v#{Kettle::Jem::Version::VERSION} begin =="
rescue LoadError, StandardError => e
  warn("[kettle-jem] ERROR: could not load bootstrap runtime (#{e.class}: #{e.message})")
  warn(e.backtrace.join("\n")) if ENV["DEBUG"]
  exit(1)
end

# Always execute when this file is loaded (e.g., via a Bundler binstub).
# Do not guard with __FILE__ == $PROGRAM_NAME because binstubs use Kernel.load.
if ARGV.include?("-h") || ARGV.include?("--help")
  puts <<~USAGE
    Usage: kettle-jem [options]

    Primary entry point for adopting kettle-jem in a host gem repository.

    First-run behavior:
      - if .kettle-jem.yml is missing, seed it from the template and exit early
      - after you review and commit that config, re-run kettle-jem to continue

    Configured-project behavior:
      - perform the bootstrap/update workflow
      - finish by invoking rake kettle:jem:install

    Related rake tasks:
      - kettle:jem:template smart-merges template files according to .kettle-jem.yml
      - kettle:jem:install runs template, then post-template checks/prompts

    Options (passed through to rake kettle:jem:install once bootstrap continues):
      --allowed=VAL           Acknowledge prior direnv allow, etc.
      --force                 Accept prompts non-interactively
      --quiet                 Run quieter setup commands and downstream install steps
      --hook_templates=VAL    Control git hook templating (local, global, skip)
      --only=VAL              Restrict install scope
      --include=VAL           Include optional files by glob
      --failure-mode=VAL      Merge failure handling: error (default) or rescue

    Environment:
      DEBUG=true              Print backtraces on errors
  USAGE
  exit 0
end

begin
  Kettle::Jem::SetupCLI.new(ARGV).run!
rescue LoadError => e
  warn("#{script_basename}: could not load dependency: #{e.class}: #{e.message}")
  warn(e.backtrace.join("\n")) if ENV["DEBUG"]
  exit(1)
rescue SystemExit => e
  warn("#{script_basename}: exited (status=#{e.status}, msg=#{e.message})") if e.status != 0
  raise
rescue StandardError => e
  warn("#{script_basename}: unexpected error: #{e.class}: #{e.message}")
  warn(e.backtrace.join("\n")) if ENV["DEBUG"]
  exit(1)
end
