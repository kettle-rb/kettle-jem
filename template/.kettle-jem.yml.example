# kettle-jem configuration file
# This file defines merge strategies and options for template files.
#
# Structure:
#   - "defaults": Default merge options applied when strategy is "merge"
#   - "patterns": Glob patterns for fallback matching (evaluated in order)
#   - "files": Nested directory structure for per-file configuration
#
# The key structure under "files" mirrors the directory hierarchy.
# Individual file configs override pattern matches, which override defaults.
#
# Strategies:
#   strategy: "merge" | "skip" | "raw_copy"
#     - "merge" (DEFAULT when no config entry matches):
#         Token resolution is applied. The appropriate AST-aware merge gem
#         is selected based on file type (prism-merge for Ruby, psych-merge
#         for YAML, bash-merge for shell, markdown-merge for Markdown, etc.)
#         and the destination file's content is intelligently merged with the
#         template. Merge options below control the behavior.
#     - "skip": Apply token resolution but do NOT merge with destination.
#         The token-resolved template content replaces the destination file.
#         Use for files where merging is not desired but tokens must be resolved.
#     - "raw_copy": Copy the file verbatim from the template — no token
#         resolution, no merging, no post-processing. Use for binary files
#         or files that must be preserved exactly as-is (e.g., certificates).
#
# Merge options (only used when strategy is "merge"):
#   preference: "template" | "destination"
#     - "template": Template nodes take precedence over destination nodes
#     - "destination": Destination nodes take precedence over template nodes
#   add_template_only_nodes: true | false
#     - true: Add nodes that exist only in template to destination
#     - false: Only merge/replace existing nodes
#   freeze_token: string (default: "kettle-jem")
#     - Token used to mark frozen sections that should not be modified
#   max_recursion_depth: number (default: Infinity)
#     - Maximum depth for recursive merging
#
# NOTE: Only files/patterns that OVERRIDE the default "merge" strategy need
# to be listed here. Any file not matched by a "files" entry or a "patterns"
# glob will be merged automatically.

# Default merge options
defaults:
  preference: "template"
  add_template_only_nodes: true
  freeze_token: "kettle-jem"

# Glob patterns evaluated in order (first match wins)
patterns:
  - path: "certs/**"
    strategy: raw_copy

# Per-file configuration (nested directory structure)
# Only files that need skip or raw_copy are listed; everything else defaults to merge.
files: {}

# To override specific files, add entries like:
#
# files:
#   "some-binary-file.dat":
#     strategy: raw_copy
#
#   "some-file-to-always-replace.txt":
#     strategy: skip
#
#   "Rakefile":
#     strategy: merge
#     preference: "destination"
#     add_template_only_nodes: false
